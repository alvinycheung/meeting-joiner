#!/bin/bash
# Run both meeting scripts — called by launchd every 60s
# Each script exits early if there's nothing to do, so this is lightweight

DIR="$HOME/.claude/meeting-joiner"

# Prevent overlapping runs via lock file
LOCKFILE="/tmp/meeting-joiner.lock"
if ! mkdir "$LOCKFILE" 2>/dev/null; then
    # Check if lock is stale (older than 2 minutes)
    if [[ -d "$LOCKFILE" ]] && [[ $(( $(date +%s) - $(stat -f %m "$LOCKFILE") )) -gt 120 ]]; then
        rm -rf "$LOCKFILE"
        mkdir "$LOCKFILE" 2>/dev/null || exit 0
    else
        exit 0
    fi
fi
trap 'rm -rf "$LOCKFILE"' EXIT

# Run check-meetings (opens links before meetings)
/bin/bash "$DIR/check-meetings.sh"

# Run announce-meetings (TTS announcements)
/bin/bash "$DIR/announce-meetings.sh"
